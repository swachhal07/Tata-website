# Admin console session (Express server)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=set-a-real-password
ADMIN_SESSION_SECRET=run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` to generate

# MongoDB (Atlas free tier M0)
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?appName=<name>
MONGODB_DB=tata_hitachi

# Cloudinary — single env var, SDK auto-reads it
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Optional — server defaults to 3001
# PORT=3001
